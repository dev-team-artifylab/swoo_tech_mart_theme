  <nav class="text-[14px] text-gray-400 mb-10 py-4 px-2">
    <a href="/" class="hover:text-black">Home</a> <span class="mx-2">/</span> 
    <a href="/shop" class="hover:text-black">Shop</a> <span class="mx-2">/</span> 
    <span class="text-black font-bold">Top Cell Phones & Tablets</span>
  </nav>


<section class="max-w-[1360px] mx-auto px-4 py-10 font-sans">
  <h2 class="text-[20px] font-bold uppercase tracking-wide mb-6 text-gray-900 py-4">
    {{ section.settings.main_title }}
  </h2>

  <div class="flex flex-col lg:flex-row gap-5">
    
    <div class="relative w-full lg:w-[864px] h-[310px] rounded-xl overflow-hidden shadow-sm">
      <div class="swiper leftHeroSwiper h-full w-full">
        <div class="swiper-wrapper">
          {% for block in section.blocks %}
            <div class="swiper-slide relative">
              
              {% if block.settings.image %}
                <img 
                  src="{{ block.settings.image | image_url: width: 1000 }}"
                  class="absolute inset-0 w-full h-full object-cover object-[85%_center]"
                  loading="lazy"
                >
              {% else %}
                 <div class="absolute inset-0 bg-slate-300"></div>
              {% endif %}

              <div class="absolute inset-0 bg-black/5"></div>

              <div class="absolute left-[40px] top-1/2 -translate-y-1/2 text-white z-10">
                <h2 class="text-[32px] font-bold py-2 leading-tight max-w-[300px]">
                  {{ block.settings.title1 }}
                </h2>
                <h3 class="text-[28px] font-light opacity-90 mb-[5px]">
                  {{ block.settings.title2 }}
                </h3>
                <div class="text-[13px] leading-relaxed max-w-[200px] text-gray-600 mb-6 py-2">
                  {{ block.settings.desc | newline_to_br }}
                </div>
                <a href="{{ block.settings.link }}" class="bg-white text-black px-[24px] py-[10px] rounded-full text-[13px] font-bold shadow-sm hover:bg-gray-50 transition">
                  {{ block.settings.btn }}
                </a>
              </div>
            </div>
          {% endfor %}
        </div>
        
        <div class="swiper-pagination !bottom-6 !left-auto !right-10 !w-auto bg-white/90 px-4 py-1 rounded-full text-[11px] font-bold tracking-widest shadow-sm"></div>
      </div>
    </div>

    <div class="relative w-full lg:w-[428px] h-[310px] rounded-xl overflow-hidden bg-[#f3f6f9] shadow-sm">
      {% if section.settings.right_image %}
        <img 
          src="{{ section.settings.right_image | image_url: width: 800 }}"
          class="absolute inset-0 w-full h-full object-cover object-right-bottom"
        >
      {% endif %}
      
      <div class="absolute left-[40px] top-1/3  -translate-y-1/2 z-10">
        <h2 class="text-[28px] font-bold leading-tight text-gray-900">
          {{ section.settings.right_title1 }}
        </h2>
        <p class="text-[14px] text-gray-500 mt-2 mb-6 py-4">
          {{ section.settings.right_desc }}
        </p>
        <a href="{{ section.settings.right_link }}" class="bg-black text-white px-[24px] py-[10px] rounded-full text-[13px] font-bold hover:bg-gray-800 transition">
          SHOP NOW
        </a>
      </div>
    </div>

  </div>
</section>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    new Swiper('.leftHeroSwiper', {
      loop: true,
      pagination: {
        el: '.swiper-pagination',
        type: 'fraction',
      },
    });
  });
</script>

{% schema %}
{
  "name": "Custom Hero Grid",
  "settings": [
    {
      "type": "text",
      "id": "main_title",
      "label": "Main Section Title",
      "default": "TOP CELL PHONES & TABLETS"
    },
    {
      "type": "header",
      "content": "Right Card Settings"
    },
    {
      "type": "image_picker",
      "id": "right_image",
      "label": "Right Side Image"
    },
    {
      "type": "text",
      "id": "right_title1",
      "label": "Right Title",
      "default": "redmi note 12 Pro+ 5g"
    },
    {
      "type": "text",
      "id": "right_desc",
      "label": "Right Subtext",
      "default": "Rise to the challenge"
    },
    {
      "type": "url",
      "id": "right_link",
      "label": "Right Button Link"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slider Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background Image"
        },
        {
          "type": "text",
          "id": "title1",
          "label": "Bold Title",
          "default": "Noise Cancelling"
        },
        {
          "type": "text",
          "id": "title2",
          "label": "Light Title",
          "default": "Headphone"
        },
        {
          "type": "textarea",
          "id": "desc",
          "label": "Description",
          "default": "Boso Over-Ear Headphone\nWifi, Voice Assistant"
        },
        {
          "type": "text",
          "id": "btn",
          "label": "Button Text",
          "default": "BUY NOW"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Button Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Hero Grid"
    }
  ]
}
{% endschema %}