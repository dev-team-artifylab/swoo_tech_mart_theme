<section class="max-w-[1360px] mx-auto min-h-[680px] bg-white flex mt-10 gap-[30px] font-sans">
    <!-- Left Sidebar -->
    <div class="w-[255px] min-h-[620px] ml-[30px] flex flex-col p-[20px] gap-[10px] border border-gray-100 rounded-lg shadow-sm">
        <img src="{{ 'profile.png' | asset_url }}" alt="Profile Picture" class="w-[213px] h-[213px] object-cover mx-auto bg-gray-100 mb-2">
        <h2 class="text-[20px] font-bold">Mark Cole</h2>
        <p class="text-[14px] text-gray-500 mb-3">swoo@gmail.com</p>

        <div class="flex flex-col gap-2 w-full">
            <a href="#" class="flex items-center justify-between px-4 py-3 rounded-md bg-[#16b52a] text-white text-sm font-medium">
                <span>Account info</span>
                <img src="{{ 'Symbol.png' | asset_url }}" alt="Icon" class="w-[14px] h-[14px] filter brightness-0 invert">
            </a>

            <a href="#" class="flex items-center justify-between px-4 py-3 rounded-md hover:bg-gray-50 text-gray-700 text-sm font-medium transition cursor-pointer">
                <span>My Order</span>
                <img src="{{ 'Symbol.png' | asset_url }}" alt="Icon" class="w-[14px] h-[14px] opacity-40">
            </a>

            <a href="#" class="flex items-center justify-between px-4 py-3 rounded-md hover:bg-gray-50 text-gray-700 text-sm font-medium transition cursor-pointer">
                <span>My address</span>
                <img src="{{ 'Symbol.png' | asset_url }}" alt="Icon" class="w-[14px] h-[14px] opacity-40">
            </a>

            <a href="#" class="flex items-center justify-between px-4 py-3 rounded-md hover:bg-gray-50 text-gray-700 text-sm font-medium transition cursor-pointer">
                <span>Change password</span>
                <img src="{{ 'Symbol.png' | asset_url }}" alt="Icon" class="w-[14px] h-[14px] opacity-40">
            </a>
        </div>
    </div>
    
    <!-- Right Content Area -->
    <div class="profile-info w-[962px] min-h-[620px] bg-white pt-5">
        <h1 class="text-[28px] font-bold text-gray-900 mb-8 tracking-tight pb-[30px]">Account Info</h1>

        <form action="#" method="POST" class="flex flex-col gap-[25px] w-full">
            <!-- First Name and Last Name Row -->
            <div class="flex gap-[28px]">
                <div class="flex flex-col gap-2 w-[467px]">
                    <label for="first_name" class="text-[14px] font-medium text-gray-800">First Name <span class="text-red-500">*</span></label>
                    <input type="text" id="first_name" name="customer[first_name]" value="Mark" class="w-full h-[43px] border border-gray-300 rounded-md px-3 text-[14px] text-gray-700 outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition shadow-sm">
                </div>
                <div class="flex flex-col gap-2 w-[467px]">
                    <label for="last_name" class="text-[14px] font-medium text-gray-800">Last Name <span class="text-red-500">*</span></label>
                    <!-- In the image, this input is selected with a blue border -->
                    <input type="text" id="last_name" name="customer[last_name]" value="Cole" class="w-full h-[43px] border border-blue-400 rounded-md px-3 text-[14px] text-gray-700 outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition shadow-sm">
                </div>
            </div>

            <!-- Email Address Row -->
            <div class="flex flex-col gap-2 w-[962px]">
                <label for="email" class="text-[14px] font-medium text-gray-800">Email Address <span class="text-red-500">*</span></label>
                <input type="email" id="email" name="customer[email]" value="swoo@gmail.com" class="w-full h-[43px] border border-gray-300 rounded-md px-3 text-[14px] text-gray-700 outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition shadow-sm">
            </div>

            <!-- Phone Number Row -->
            <div class="flex flex-col gap-2 w-[962px]">
                <label for="phone" class="text-[14px] font-medium text-gray-800">Phone Number <span class="text-gray-400 font-normal">(Optional)</span></label>
                <input type="tel" id="phone" name="customer[phone]" value="+1 0231 4554 452" class="w-full h-[43px] border border-gray-300 rounded-md px-3 text-[14px] text-gray-700 outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition shadow-sm">
            </div>

            <!-- Submit Button -->
            <button type="submit" class="w-[140px] h-[50px] bg-[#16b52a] text-white text-[13px] rounded-md font-bold tracking-wider hover:bg-green-700 transition mt-6">
                SAVE
            </button>
        </form>
    </div>
</section>

{% schema %}
{
  "name": "Custom Profile",
  "settings": [],
  "presets": [
    {
      "name": "Custom Profile"
    }
  ]
}
{% endschema %}

