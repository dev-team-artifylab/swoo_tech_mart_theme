<section class="bg-gray-200 max-w-[1240px] max-h-[257px]">
  <!-- Header -->
  <div class="flex justify-between items-center py-4 px-4">
    <h2 class="text-l font-semibold">
      {{ section.settings.heading }}
    </h2>

    <div class="text-xs">
      <a href="{{ section.settings.view_all_link }}">
        {{ section.settings.view_all_text }}
      </a>
    </div>
  </div>

  <div class="flex flex-row gap-4">
    <div class="slider px-4">
      <div
        class="relative h-[200px] md:w-[450px] lg:w-[605px] rounded-lg overflow-hidden bg-cover bg-center flex items-center"

        {% if section.settings.banner_image %}
          style="background-image: url('{{ section.settings.banner_image | image_url: width: 1200 }}');"
        {% endif %}
      >

        <!-- Content -->
        <div class="relative z-10 text-white px-6 max-w-[60%] flex flex-col gap-2">
          <h2 class="text-lg md:text-xl lg:text-2xl font-bold max-w-[160px] leading-tight">
            {{ section.settings.banner_heading }}
          </h2>

          <p class="text-xs mt-1 opacity-90">
            {{ section.settings.banner_subtext }}
          </p>

          <a
            href="{{ section.settings.banner_button_link }}"
            class="inline-block mt-3 px-4 py-2 bg-black text-white text-xs rounded-md w-[102px] h-[32px]"
          >
            {{ section.settings.banner_button_text }}
          </a>
        </div>

      </div>
    </div>

    <!-- Categories -->
    <div class="grid grid-cols-2 sm:grid-cols-2 md:grid-cols-2 lg:grid-cols-3 gap-4 lg:gap-8 py-2">
      {% if section.blocks.size == 0 %}
        <div class="col-span-full flex items-center justify-center min-h-[200px]">
          <p class="text-sm text-gray-500">Add collections to display categories</p>
        </div>
      {% endif %}

      {% for block in section.blocks %}
        {% render 'collection-snp', block: block %}
      {% endfor %}
    </div>
  </div>
</section>
<section>
  <!-- Show Tablet, Mobile Collection Here -->
</section>

{% schema %}
{
  "name": "Category Showcase",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Top Categories"
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "View All Text",
      "default": "View All"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View All Link"
    },

    /* Banner Settings */
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner Image"
    },
    {
      "type": "text",
      "id": "banner_heading",
      "label": "Banner Heading",
      "default": "REDMI NOTE 12 PRO+ 5G"
    },
    {
      "type": "text",
      "id": "banner_subtext",
      "label": "Banner Sub Text",
      "default": "Rise to the challenge"
    },
    {
      "type": "text",
      "id": "banner_button_text",
      "label": "Button Text",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "banner_button_link",
      "label": "Button Link"
    }
  ],

  "blocks": [
    {
      "type": "category_block",
      "name": "Category",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Category Title",
          "default": "Category Name"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Select Collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Category Image"
        }
      ]
    }
  ],

  "max_blocks": 6,

  "presets": [
    {
      "name": "Category Showcase",
      "blocks": [
        { "type": "category_block" },
        { "type": "category_block" },
        { "type": "category_block" }
      ]
    }
  ]
}
{% endschema %}
