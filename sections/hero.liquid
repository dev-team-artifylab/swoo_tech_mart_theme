{% schema %}
{
  "name": "Hero Section",
  "settings": [],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        { "type": "text", "id": "title", "label": "Category Name" }
      ]
    },
    {
      "type": "hero",
      "name": "Hero Banner",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Background Image" },
        { "type": "text", "id": "title1", "label": "Title Line 1" },
        { "type": "text", "id": "title2", "label": "Title Line 2" },
        { "type": "textarea", "id": "desc", "label": "Description" },
        { "type": "text", "id": "btn", "label": "Button Text" }
      ]
    },
    {
      "type": "promo_top",
      "name": "Top Right Card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "label", "label": "Small Label" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "text", "id": "btn", "label": "Button Text" }
      ]
    },
    {
      "type": "promo_bottom",
      "name": "Bottom Right Card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "brand", "label": "Brand" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "text", "id": "price", "label": "Price" }
      ]
    },
    {
      "type": "bottom_card",
      "name": "Bottom Card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "text", "id": "subtitle", "label": "Subtitle" },
        { "type": "text", "id": "link", "label": "Link Text" }
      ]
    }
  ],
  "presets": [
    { "name": "Hero Electronics Final" }
  ]
}
{% endschema %}

<section class="w-full py-6">
  <div class="max-w-[1440px] mx-auto px-6">

    <div class="grid grid-cols-12 gap-2">

      <!-- LEFT SIDEBAR -->
      <div class="col-span-3 h-[447px] bg-[#F5F5F5] rounded-xl p-[24px]">
        <p class="text-red-500 text-[14px] font-semibold mb-[18px]">
          SALE 40% OFF
        </p>

        <ul class="space-y-[14px] text-[14px] text-gray-800">
          {% for block in section.blocks %}
            {% if block.type == 'category' %}
              <li>{{ block.settings.title }}</li>
            {% endif %}
          {% endfor %}
        </ul>
      </div>

      <!-- CENTER -->
      <div class="col-span-6  w-[650px] h-[310px] rounded-xl">

        {% for block in section.blocks %}
        {% if block.type == 'hero' %}

        <!-- HERO -->
        <div class="relative w-[650px] h-[310px] rounded-xl overflow-hidden">

          {% if block.settings.image %}
            <img 
              src="{{ block.settings.image | image_url }}"
              class="absolute inset-0 w-full h-full object-cover object-[85%_center]"
            >
          {% endif %}

          <!-- LIGHT OVERLAY -->
          <div class="absolute inset-0 bg-black/10"></div>

          <!-- TEXT -->
          <div class="absolute left-[30px] top-1/3 -translate-y-1/2 text-white ">

            <h2 class="text-[28px] font-sans  font-bold leading-tight max-w-[250px]">
              {{ block.settings.title1 }}
            </h2>

            <h3 class="text-[28px] font-light opacity-90 mb-[10px]">
              {{ block.settings.title2 }}
            </h3>

            <p class="  px-4  text-[12px] leading-relaxed w-[151px]">
              {{ block.settings.desc }}
            </p>

            <button class= " mt-6 bg-white text-black px-[18px] py-[6px] rounded-full text-[13px] font-medium">
              {{ block.settings.btn }}
            </button>

          </div>

          <!-- SLIDER -->
          <div class="absolute bottom-[18px] right-[40px] bg-white px-[12px] py-[6px] rounded-full text-[13px] flex gap-3 items-center shadow">
            <span>◀</span>
            <span>3 / 3</span>
            <span>▶</span>
          </div>

        </div>

        {% endif %}
        {% endfor %}

        <!-- BOTTOM CARDS -->
        <div class="grid grid-cols-1 pt-4  md:grid-cols-2 gap-5 mt-6">
  {% for block in section.blocks %}
    {% if block.type == 'bottom_card' %}
      
      {% comment %} 
        Check if 'Keyboard' is in the title to apply dark mode styling 
      {% endcomment %}
      {% assign is_dark = false %}
      {% if block.settings.title contains 'Keyboard' or block.settings.title contains 'Logitek' %}
        {% assign is_dark = true %}
      {% endif %}

      <div class="{% if is_dark %}bg-[#4B5563] text-white{% else %}bg-white border border-gray-100{% endif %} rounded-2xl relative h-[120px] overflow-hidden group shadow-sm transition-hover hover:shadow-md">
        
        <div class="absolute left-[20px] top-1/2 -translate-y-1/2 z-10">
          <h5 class="text-[16px] font-bold leading-tight">
            {% if is_dark %}
              {{ block.settings.title | replace: 'Keyboard', '<span class="text-[#FACC15]">Keyboard</span>' }}
            {% else %}
              {{ block.settings.title }}
            {% endif %}
          </h5>

          {% if is_dark %}
            <p class="text-[11px] text-gray-300 italic">
              {{ block.settings.subtitle }}
            </p>
          {% else %}
            <p class="text-[14px] mt-1">
              from <span class="text-[#16A34A] font-bold">{{ block.settings.subtitle }}</span>
            </p>
            <a href="{{ block.settings.url }}" class="inline-block mt-3 text-[11px] font-bold uppercase tracking-tighter border-b-2 border-current pb-0.5 hover:text-red-600 hover:border-red-600 transition-colors">
              {{ block.settings.link | default: 'Discover Now' }}
            </a>
          {% endif %}
        </div>

        {% if block.settings.image %}
          <img 
            src="{{ block.settings.image | img_url: '400x' }}"
            alt="{{ block.settings.title }}"
            class="absolute right-[10px] top-1/2 -translate-y-1/2 h-[80%] w-auto object-contain transition-transform duration-300 group-hover:scale-110 {% if is_dark %}-rotate-6 group-hover:rotate-0{% endif %}"
          >
        {% endif %}

        <div class="absolute inset-0 bg-black/10"></div>

      </div>
    {% endif %}
  {% endfor %}
</div>

      </div>

      <!-- RIGHT SIDE -->
<div class="col-span-3 flex flex-col gap-4">

  {% for block in section.blocks %}

  <!-- 🔼 TOP CARD -->
  {% if block.type == 'promo_top' %}
  <div class="relative h-[215px] rounded-xl overflow-hidden">

    <!-- Background Image -->
    {% if block.settings.image %}
      <img 
        src="{{ block.settings.image | image_url }}"
        class="absolute inset-0 w-full h-full object-cover object-[85%_center]"
      >
    {% endif %}

    <!-- Overlay -->
    <div class="absolute inset-0 bg-black/10"></div>

   <div class="absolute  float-right pl-[20px] mr-[20px] right-[20px] top-[20px] max-w-[140px] text-right z-10">

  <p class="text-[11px] text-gray-700 mb-[4px]">
    {{ block.settings.label }}
  </p>

  <h4 class="text-[16px] font-semibold  max-w-full text-right mb-[10px]">
    {{ block.settings.title }}
  </h4>

  <button class="ml-auto block bg-gray-800 text-white px-[12px] py-[5px] rounded-full text-[11px]">
    {{ block.settings.btn }}
  </button>

</div>

  </div>
  {% endif %}


  <!-- 🔽 BOTTOM CARD -->
  {% if block.type == 'promo_bottom' %}
  <div class="relative h-[215px] rounded-xl overflow-hidden text-white">

    <!-- Background Image -->
    {% if block.settings.image %}
      <img 
        src="{{ block.settings.image | image_url }}"
        class="absolute inset-0 w-full h-full object-cover"
      >
    {% endif %}

    <!-- Dark Overlay -->
    <div  class="absolute inset-s-0 bg-black/40"></div>

    <!-- Content (FRONT) -->
    <div class="absolute left-[20px] top-[20px] z-10">

      <p class="text-[12px] opacity-80">
        {{ block.settings.brand }}
      </p>

      <h4 class="text-[20px] font-semibold leading-tight mt-[4px] mb-[10px]">
        {{ block.settings.title }}
      </h4>

      <p class="text-green-400 text-[18px] font-semibold">
        {{ block.settings.price }}
      </p>

    </div>

  </div>
  {% endif %}

  {% endfor %}

</div>

    </div>

  </div>
</section>