<div class="frequenty-visited-products-div max-w-[1240px] h-[400px] flex p-4 mx-auto">
  <div class="w-[890px] max-h-[367px] bg-gray-200 p-4">
    <h5 class="text-l font-bold">Frequenty Bought Together</h5>
    <div class="max-w-[741px] h-[300px] p-4 flex gap-6">
      <div class="flex flex-col gap-4">
        <div class="flex gap-4">
          <div class="w-[190px] h-[200px] bg-green-200"><p>Image</p></div>
          <div class="w-[190px] h-[200px] bg-green-300"><p>Image</p></div>
          <div class="w-[190px] h-[200px] bg-green-400"><p>Image</p></div>
        </div>
        <p>
          Lorem ipsum, dolor sit amet consectetur adipisicing elit. Optio, voluptates eius quae amet eaque libero illo
          dignissimos! Neque, quibusdam debitis!
        </p>
      </div>
      <div class="flex flex-col gap-2 min-w-[200px] ">
        <p>Total Price</p>
        <h3 class="text-xl font-bold">$ 609</h3>
        <button class="bg-green-400 py-1 rounded-lg font-bold">Add To Cart</button>
        <p class="text-xs">Add To Wishlist</p>
      </div>
    </div>
  </div>

  <!-- Right Section: Custom Images -->
  <div class="img-1 w-[334px] flex flex-col gap-1 h-full px-2">
    {% if section.settings.side_image_1 %}
      <div class="w-full h-[200px]">
        <img
          src="{{ section.settings.side_image_1 | img_url: '334x200' }}"
          alt="Side Image 1"
          class="w-full h-full object-cover"
        >
      </div>
    {% endif %}

    {% if section.settings.side_image_2 %}
      <div class="w-full h-[200px]">
        <img
          src="{{ section.settings.side_image_2 | img_url: '334x200' }}"
          alt="Side Image 2"
          class="w-full h-full object-cover"
        >
      </div>
    {% endif %}
  </div>
</div>
