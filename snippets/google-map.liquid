<div id="map" class="h-[450px] w-full"></div>

<script>
  function initMap() {
    // Create a new map centered on the location
    var lucca = { lat: 43.8431, lng: 10.5076 };
    var map = new google.maps.Map(document.getElementById('map'), {
      zoom: 16,
      center: lucca,
      mapTypeControl: false,
      streetViewControl: false,
      fullscreenControl: false,
    });

    // Create a custom info window content
    var contentString = `
      <div class="map-info-window">
        <h3>Chiesa di San Francesco</h3>
        <p>Piazza S. Francesco, 55100 Lucca LU, Italy</p>
        <div class="rating">
          <span>4.5</span>
          <a href="#">944 reviews</a>
        </div>
        <a href="#" class="directions-link">Directions</a>
      </div>
    `;

    // Create the info window
    var infowindow = new google.maps.InfoWindow({
      content: contentString,
      position: lucca,
      pixelOffset: new google.maps.Size(0, -40),
    });

    // Open the info window automatically
    infowindow.open(map);
  }
</script>
<script async defer src="https://maps.googleapis.com/maps/api/js?key=YOUR_API_KEY&callback=initMap"></script>