<div class="w-[1360px] mx-auto px-6 py-16 font-sans">
  
  <nav class="text-[14px] text-gray-400 mb-10 py-4">
    <a href="/" class="hover:text-black">Home</a> <span class="mx-2">/</span> 
    <a href="/shop" class="hover:text-black">Shop</a> <span class="mx-2">/</span> 
    <span class="text-black font-bold">Contact</span>
  </nav>

  <div class="flex flex-col gap-4 py-4 lg:flex-row gap-12 py-6">
    
    <div class="w-full">
      <h2 class="text-[18px] font-bold tracking-[0.2em] py-6 uppercase mb-4 text-slate-900">Ready to work with us</h2>
      <p class="text-gray-500 text-[15px] mb-6 py-6">Contact us for all your questions and opinions</p>

      {% form 'contact', class: 'space-y-5' %}
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5 ">
          <div class="flex flex-col">
            <label class="text-[13px] font-semibold mb-2 py-2">First Name <span class="text-red-500">*</span></label>
            <input type="text" name="contact[first_name]" placeholder="Enter your first name" class="border border-gray-200 rounded-md p-3 focus:ring-1 focus:ring-green-500 outline-none transition">
          </div>
          <div class="flex flex-col">
            <label class="text-[13px] font-semibold mb-2 py-2">Last Name <span class="text-red-500">*</span></label>
            <input type="text" name="contact[last_name]" placeholder="Enter your last name" class="border border-gray-200 rounded-md p-3 focus:ring-1 focus:ring-green-500 outline-none transition">
          </div>
        </div>

        <div class="flex flex-col">
          <label class="text-[13px] font-semibold mb-2 py-2">Email Address <span class="text-red-500">*</span></label>
          <input type="email" name="contact[email]" class="border border-gray-200 rounded-md p-3 focus:ring-1 focus:ring-green-500 outline-none transition">
        </div>

        <div class="flex flex-col">
          <label class="text-[13px] font-semibold mb-2 py-2 text-gray-400">Phone Number (Optional)</label>
          <input type="tel" name="contact[phone]" class="border border-gray-200 rounded-md p-3 focus:ring-1 focus:ring-green-500 outline-none transition">
        </div>

        <div class="flex flex-col">
          <label class="text-[13px] font-semibold mb-2 py-2">Country / Region <span class="text-red-500">*</span></label>
          <select name="contact[country]" class="border border-gray-200 rounded-md p-3 bg-white outline-none">
            <option>United States (US)</option>
            <option>United Kingdom (UK)</option>
          </select>
        </div>

        <div class="flex flex-col">
          <label class="text-[13px] font-semibold mb-2 py-2 text-gray-400">Subject (Optional)</label>
          <input type="text" name="contact[subject]" class="border border-gray-200 rounded-md p-3 outline-none">
        </div>

        <div class="flex flex-col">
          <label class="text-[13px] font-semibold mb-2 py-2">Message</label>
          <textarea name="contact[body]" rows="6" placeholder="Note about your order, e.g. special note for delivery" class="border border-gray-200 rounded-md p-3 outline-none focus:ring-1 focus:ring-green-500 transition"></textarea>
        </div>

        <div class="flex items-start gap-3 py-2">
          <input type="checkbox" id="consent" class="mt-1 w-4 h-4 py-2 accent-green-600">
          <label for="consent" class="text-[12px] text-gray-500   leading-tight">
            I want to receive news and updates once in a while. By submitting, I’m agreed to the <a href="#" class="text-green-800 font-bold hover:underline">Terms & Conditions</a>
          </label>
        </div>

        <button type="submit" class="bg-[#28B628] hover:bg-green-700 text-white font-bold text-[12px] tracking-widest px-10 py-4 rounded-md transition-all duration-300">
          SEND MESSAGE
        </button>
      {% endform %}
    </div>

    <div class="w-[524px]  flex flex-col gap-8">
      
      <div class="bg-[#767575] p-8 rounded-xl border border-gray-100">
        <div class="mb-10">
          <h4 class="text-[10px] font-bold text-gray-400 uppercase tracking-[0.15em] mb-4 py-4">United States (Head Quarter)</h4>
          <p class="text-[14px] leading-relaxed mb-1">152 Thatcher Road St, Mahattan, 10463, US</p>
          <p class="text-[14px] mb-1">(+025) 3886 25 16</p>
          <a href="mailto:hello@swattechmart.com" class="text-green-600 text-[14px] font-medium">hello@swattechmart.com</a>
        </div>

        <div class="mb-8">
          <h4 class="text-[10px] font-bold text-gray-400 uppercase tracking-[0.15em] mb-4 py-4">United Kingdom (Branch)</h4>
          <p class="text-[14px] leading-relaxed mb-1">12 Buckingham Rd, Thornthwaite, HG3 4TY, UK</p>
          <p class="text-[14px] mb-1">(+718) 895-5350</p>
          <a href="mailto:contact@swattechmart.co.uk" class="text-green-600 text-[14px] font-medium">contact@swattechmart.co.uk</a>
        </div>

        <div class="flex gap-3">
          <div class="w-8 h-8 rounded-full bg-white flex items-center justify-center text-gray-600 border border-gray-100 cursor-pointer hover:bg-green-600 hover:text-white transition shadow-sm text-xs">𝕏</div>
          <div class="w-8 h-8 rounded-full bg-white flex items-center justify-center text-gray-600 border border-gray-100 cursor-pointer hover:bg-green-600 hover:text-white transition shadow-sm text-xs">f</div>
          <div class="w-8 h-8 rounded-full bg-white flex items-center justify-center text-gray-600 border border-gray-100 cursor-pointer hover:bg-green-600 hover:text-white transition shadow-sm text-xs">📷</div>
        </div>
      </div>

      <div class="rounded-xl overflow-hidden shadow-md">
        <img src="https://images.unsplash.com/photo-1499750310107-5fef28a66643?q=80&w=800&auto=format&fit=crop" class="w-full grayscale object-cover h-[280px]">
      </div>
    </div>

    

  </div>
  <div class="mt-20 h-[450px]">
            <h2 class="text-[18px] font-bold text-gray-400 uppercase tracking-widest mb-6 py-2">FIND US ON GOOGLE MAP</h2>
            <div class="rounded-xl overflow-hidden shadow-sm border border-gray-100 h-[450px]">
                <iframe 
                    src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d193595.15830869428!2d-74.119763973046!3d40.69766374874431!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89c24fa5d33f083b%3A0xc80b8f06e177fe62!2sNew%20York%2C%20NY!5e0!3m2!1sen!2sus!4v1711825000000!5m2!1sen!2sus" 
                    width="100%" 
                    height="100%" 
                    style="border:0;" 
                    allowfullscreen="" 
                    loading="lazy">
                </iframe>
            </div>
        </div>
</div>